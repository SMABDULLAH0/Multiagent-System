STARTUP_IDEA=A platform where students buy and sell second-hand textbooks with campus-only trust signals.

# LLM
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_REPOSITORY=your-username/launchmind-your-group
GITHUB_BASE_BRANCH=main

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#launches

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=verified-sender@example.com
SENDGRID_TO_EMAIL=test-inbox@example.com

# Runtime
ENABLE_QA_AGENT=true
LAUNCHMIND_FORCE_FEEDBACK_LOOP=true
OUTPUT_DIR=artifacts

